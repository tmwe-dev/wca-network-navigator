{
  "manifest_version": 3,
  "name": "LinkedIn Cookie Sync",
  "version": "3.7.0",
  "description": "Login automatico + sincronizzazione cookie li_at + estrazione profili LinkedIn. v3.7.0 anti-multitab (M1), dedup inbox + filtro notification (M2), brief tab activation (M5).",
  "permissions": ["cookies", "tabs", "activeTab", "scripting", "debugger", "storage"],
  "host_permissions": ["https://*.linkedin.com/*", "https://www.linkedin.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.lovable.app/*",
        "https://*.lovableproject.com/*",
        "http://localhost:*/*",
        "*://localhost:*/*",
        "http://127.0.0.1:*/*",
        "*://127.0.0.1:*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
