{
  "manifest_version": 3,
  "name": "LinkedIn Cookie Sync",
  "version": "3.1",
  "description": "Login automatico + sincronizzazione cookie li_at + estrazione profili LinkedIn. Architettura modulare ibrida AX Tree + Optimus AI Self-Healing (payload nested bridge).",
  "permissions": ["cookies", "tabs", "activeTab", "scripting", "debugger", "storage"],
  "host_permissions": ["https://*.linkedin.com/*", "https://www.linkedin.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.lovable.app/*",
        "https://*.lovableproject.com/*",
        "http://localhost:*/*",
        "*://localhost:*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}