{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "types": ["chrome"]
  },
  "include": ["**/*.js", "**/*.mjs", "types/**/*.d.ts"],
  "exclude": ["**/bridge/server.js"]
}
