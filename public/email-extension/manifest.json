{
  "manifest_version": 3,
  "name": "Universal Communication Hub",
  "version": "3.0.0",
  "description": "Email, WhatsApp e LinkedIn in un'unica estensione. Download locale, sync cloud, agente AI integrato.",
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "downloads",
    "sidePanel"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "minimum_chrome_version": "114"
}