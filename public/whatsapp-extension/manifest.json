{
  "manifest_version": 3,
  "name": "WCA WhatsApp Bridge v5.10",
  "version": "5.10.0",
  "description": "Optimus V2.1 — automation window isolation (no focus stealing), stabilize+unified extract+AI relearn, direct-first edge function, multi-segnale scoring",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "webNavigation",
    "storage"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://*.lovable.app/*",
    "https://*.lovableproject.com/*",
    "http://localhost:*/*",
    "*://localhost:*/*",
    "http://127.0.0.1:*/*",
    "*://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.lovable.app/*",
        "https://*.lovableproject.com/*",
        "http://localhost:*/*",
        "*://localhost:*/*",
        "http://127.0.0.1:*/*",
        "*://127.0.0.1:*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
