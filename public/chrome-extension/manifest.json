{
  "manifest_version": 3,
  "name": "WCA Cookie Sync",
  "version": "3.0",
  "description": "Login automatico + sincronizzazione cookie + estrazione contatti WCA.",
  "permissions": ["cookies", "tabs", "activeTab", "scripting"],
  "host_permissions": ["https://*.wcaworld.com/*", "https://wcaworld.com/*", "https://www.wcaworld.com/*", "https://zrbditqddhjkutzjycgi.supabase.co/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.lovable.app/*",
        "https://*.lovableproject.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
